# --- Frontend Environment Variables ---
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# API Base URL for local development (defaults to relative /api handled by Vite proxy)
# Set this to http://127.0.0.1:3000 if you want the frontend to hit the backend directly.
# VITE_API_URL=http://127.0.0.1:3000

# Formspree endpoint for contact/application forms
VITE_FORM_ENDPOINT=https://formspree.io/f/your-form-id

# Cloudflare Turnstile Site Key for form protection
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key


# --- Backend Environment Variables (Vercel Serverless Functions) ---
# DANGER: Never expose the SERVICE_ROLE_KEY to the frontend (VITE_ prefixed).
# This key bypasses Row Level Security and should only be used in server-side functions.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Groq API Key for the AI Market Guide analysis engine
GROQ_API_KEY=your-groq-api-key
