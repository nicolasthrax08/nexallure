# --- Frontend Environment Variables ---
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: Form endpoint for contact forms (e.g., Formspree)
# VITE_FORM_ENDPOINT=https://formspree.io/f/your-form-id


# --- Backend Environment Variables (Serverless Functions) ---
# DANGER: Never expose the SERVICE_ROLE_KEY to the frontend (VITE_ prefixed).
# This key bypasses Row Level Security and should only be used in /api functions.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Groq API Key for the AI Market Guide engine
GROQ_API_KEY=your-groq-api-key
